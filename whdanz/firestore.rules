rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permite todo en modo de desarrollo/prueba
    // IMPORTANTE: Cambiar a reglas restrictivas en producción
    match /{document=**} {
      allow read, write: if true;
    }
    
    /*
    // Reglas originales (para producción):
    
