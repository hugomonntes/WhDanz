rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permite todo en modo de desarrollo/prueba
    // IMPORTANTE: Cambiar a reglas restrictivas en producción
    match /{document=**} {
      allow read, write: if true;
    }
    
    /*
    // Reglas originales (para producción):
    
    // Usuarios
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Posts
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Lugares
    match /places/{placeId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.addedBy;
    }
    */
  }
}
